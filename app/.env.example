# Copy this file to .env and fill in real values. Never commit .env.

# Postgres/Supabase connection string used by Prisma at runtime — the
# restricted application role (see scripts/provision-app-role.sh), never the
# database superuser/owner.
DATABASE_URL="postgresql://tradeos_app:replace-me@localhost:5432/tradeos_costbook?schema=public"

# Elevated connection string used ONLY by scripts/deploy-migrations.sh and
# scripts/provision-app-role.sh. Migrations include forced-RLS/policy DDL
# the restricted application role is never granted permission to run, and
# that role cannot grant privileges to itself. Never use this as DATABASE_URL.
DATABASE_ADMIN_URL="postgresql://postgres:password@localhost:5432/tradeos_costbook?schema=public"

# Password for the restricted application role that scripts/deploy-migrations.sh
# / scripts/provision-app-role.sh will create or update. Required for those
# scripts to provision the role; not read by the running API itself (it just
# uses DATABASE_URL). Rotate independently of DATABASE_ADMIN_URL's credentials.
APP_DB_ROLE_PASSWORD="replace-with-a-real-secret"
# Defaults to "tradeos_app" if unset.
APP_DB_ROLE_NAME=""

# Port the API server listens on.
PORT=4000

# Proxy handling for deployments behind a load balancer or platform proxy.
# Examples: "true", "1", "loopback", "10.0.0.0/8"
TRUST_PROXY="false"

# Enable HSTS only when the app is always served over HTTPS in production.
ENABLE_STRICT_TRANSPORT_SECURITY="false"

# Secret used to verify and sign bearer JWTs in local development and self-hosted deployments.
AUTH_JWT_SECRET="replace-me"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_ISSUER=""
SUPABASE_JWT_JWKS_URL=""
SUPABASE_JWT_AUDIENCE=""

# Optional auth settings.
AUTH_ISSUER="tradeos-costbook"
AUTH_AUDIENCE="tradeos-costbook-api"

# Maximum lifetime for the request transaction that carries RLS session state.
RLS_TRANSACTION_TIMEOUT_MS=60000

# Separate high-entropy credential for first-owner organization provisioning.
# Keep this route behind network controls in production and rotate regularly.
PLATFORM_PROVISIONING_SECRET="replace-with-at-least-32-random-characters"

# Optional comma-separated IP allowlist for the provisioning route, e.g.
# "203.0.113.10,203.0.113.11". Defense-in-depth only — relies on accurate
# req.ip, so only meaningful if the app trusts a correctly configured proxy
# in front of it. Leave unset to rely entirely on infrastructure-level
# network controls (security groups, ALB rules, etc.).
PLATFORM_PROVISIONING_ALLOWED_IPS=""

# Rate limit for the provisioning route. Defaults to 5 requests per 15
# minutes per client IP if unset.
PLATFORM_PROVISIONING_RATE_LIMIT_WINDOW_MS=900000
PLATFORM_PROVISIONING_RATE_LIMIT_MAX=5

# Optional in-process scheduler for the supplier price sync job (see
# modules/supplier-integration/worker.ts). Both must be set for the
# scheduler to start — leave either unset to no-op and instead run
# `npm run jobs:supplier-price-sync` from external cron / a k8s CronJob.
# Standard 5-field cron expression, e.g. "0 * * * *" for hourly.
SUPPLIER_PRICE_SYNC_CRON_SCHEDULE=""
# JSON array of { orgId, userId, supplierId, label? } — one entry per
# org/supplier to sync. userId must be an existing user with an active
# membership in orgId; the job runs as that identity. There is no
# cross-tenant service-account concept in this app, so targets must be
# listed explicitly rather than auto-discovered.
# Example: '[{"orgId":"...","userId":"...","supplierId":"...","label":"Acme"}]'
SUPPLIER_PRICE_SYNC_JOBS=""
