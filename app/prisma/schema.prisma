// Prisma schema for TradeOS Cost Book.
// Mirrors db/migrations/0001_init_schema.sql (the source of truth for the SQL DDL).
// Run `npm run prisma:migrate` to apply this schema to a fresh database, or
// `npm run prisma:generate` to regenerate the client after editing this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String    @id @default(uuid())
  name                 String
  regionCode           String?   @map("region_code")
  logoUrl              String?   @map("logo_url")
  phone                String?
  email                String?
  address              String?
  defaultLaborRate     Decimal?  @map("default_labor_rate") @db.Decimal(10, 2)
  defaultMarkupPercent Decimal?  @map("default_markup_percent") @db.Decimal(5, 2)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  memberships    OrganizationMembership[]
  membershipAudits OrganizationMembershipAudit[]
  materialPriceAudits MaterialPriceAudit[]
  supplierPriceUpdates SupplierPriceUpdate[]
  divisions      Division[]
  regions        Region[]
  suppliers      Supplier[]
  materials      Material[]
  laborRates     LaborRate[]
  equipment      Equipment[]
  subcontractors Subcontractor[]
  costItems      CostItem[]
  assemblies     Assembly[]
  customers      Customer[]
  serviceAddresses ServiceAddress[]
  customerEquipment CustomerEquipment[]
  projects       Project[]
  jobs           Job[]
  jobAssignments JobAssignment[]
  estimates      Estimate[]
  serviceAgreements ServiceAgreement[]
  payments       Payment[]
  settings       OrganizationSettings?
  brandProfile   BrandProfile?
  brandAssets    BrandAsset[]
  brandDocumentSettings BrandDocumentSettings?
  activityEvents ActivityEvent[]
  proposalDeliveries ProposalDelivery[]
  invoiceDeliveries InvoiceDelivery[]
  contractEvents  ContractEvent[]
  notifications  Notification[]
  attachments    Attachment[]
  comments       Comment[]
  tags           Tag[]
  tagAssignments TagAssignment[]
  savedViews     SavedView[]
  recentItems    RecentItem[]
  featureFlags   FeatureFlag[]
  invites        OrganizationInvite[]
  refreshTokens  AuthRefreshToken[]

  @@map("organizations")
}

model OrganizationSettings {
  id           String   @id @default(uuid())
  orgId        String   @unique @map("org_id")
  settingsJson Json     @map("settings_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model BrandProfile {
  id                   String   @id @default(uuid())
  organizationId       String   @unique @map("organization_id")
  companyDisplayName   String?  @map("company_display_name")
  tagline              String?
  primaryColor         String?  @map("primary_color")
  secondaryColor       String?  @map("secondary_color")
  accentColor          String?  @map("accent_color")
  logoUrl              String?  @map("logo_url")
  logoDarkUrl          String?  @map("logo_dark_url")
  logoLightUrl         String?  @map("logo_light_url")
  iconUrl              String?  @map("icon_url")
  watermarkUrl         String?  @map("watermark_url")
  coverImageUrl        String?  @map("cover_image_url")
  typographyStyle      String?  @map("typography_style")
  defaultDocumentTheme String?  @map("default_document_theme")
  proposalStyle        String?  @map("proposal_style")
  invoiceStyle         String?  @map("invoice_style")
  contractStyle        String?  @map("contract_style")
  emailSignature       String?  @map("email_signature")
  websiteUrl           String?  @map("website_url")
  phone                String?
  email                String?
  addressLine1         String?  @map("address_line_1")
  addressLine2         String?  @map("address_line_2")
  city                 String?
  state                String?
  postalCode           String?  @map("postal_code")
  licenseNumber        String?  @map("license_number")
  insuranceSummary     String?  @map("insurance_summary")
  bondingSummary       String?  @map("bonding_summary")
  yearsInBusiness      Int?     @map("years_in_business")
  serviceAreasJson     Json?    @map("service_areas_json")
  certificationsJson   Json?    @map("certifications_json")
  socialLinksJson      Json?    @map("social_links_json")
  reviewLinksJson      Json?    @map("review_links_json")
  financingLinksJson   Json?    @map("financing_links_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets           BrandAsset[]
  documentSettings BrandDocumentSettings?

  @@map("brand_profiles")
}

model BrandAsset {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  brandProfileId String   @map("brand_profile_id")
  type           String
  label          String?
  url            String
  mimeType       String?  @map("mime_type")
  sizeBytes      Int?     @map("size_bytes")
  width          Int?
  height         Int?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandProfile BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@index([brandProfileId])
  @@map("brand_assets")
}

model BrandDocumentSettings {
  id                  String   @id @default(uuid())
  organizationId      String   @unique @map("organization_id")
  brandProfileId      String   @unique @map("brand_profile_id")
  showPoweredByTradeOS Boolean @default(false) @map("show_powered_by_tradeos")
  showLicenseNumber   Boolean  @default(true) @map("show_license_number")
  showInsuranceSummary Boolean @default(true) @map("show_insurance_summary")
  showGoogleRating    Boolean  @default(false) @map("show_google_rating")
  showSocialLinks     Boolean  @default(true) @map("show_social_links")
  defaultCoverMode    String?  @map("default_cover_mode")
  defaultHeaderStyle  String?  @map("default_header_style")
  defaultFooterStyle  String?  @map("default_footer_style")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandProfile BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)

  @@map("brand_document_settings")
}

model AppUser {
  id           String   @id @default(uuid())
  authSubject  String   @unique @map("auth_subject")
  email        String   @unique
  fullName     String?  @map("full_name")
  passwordHash String?  @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  memberships  OrganizationMembership[]
  reviewedSupplierPriceUpdates SupplierPriceUpdate[]
  activityEvents ActivityEvent[]
  proposalDeliveries ProposalDelivery[]
  invoiceDeliveries InvoiceDelivery[]
  contractEvents  ContractEvent[]
  notifications Notification[]
  attachments   Attachment[]
  comments      Comment[]
  savedViews    SavedView[]
  recentItems   RecentItem[]
  tagAssignments TagAssignment[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens AuthRefreshToken[]
  totpCredential UserTotpCredential?
  sentInvites   OrganizationInvite[] @relation("InviteSender")
  createdJobs   Job[]                @relation("JobCreatedBy")
  completedJobs Job[]                @relation("JobCompletedBy")
  assignedJobs  JobAssignment[]      @relation("JobAssignmentUser")
  assignedJobActions JobAssignment[] @relation("JobAssignedBy")

  @@map("users")
}

model OrganizationMembership {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String   @map("user_id")
  role       String   @default("owner")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model OrganizationMembershipAudit {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  membershipId String  @map("membership_id")
  userId      String   @map("user_id")
  action      String
  actorUserId String?  @map("actor_user_id")
  actorRole   String?  @map("actor_role")
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, membershipId, createdAt])
  @@index([userId, createdAt])
  @@map("organization_membership_audits")
}

model Division {
  id        String   @id @default(uuid())
  orgId     String?  @map("org_id")
  code      String
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  categories   Category[]

  @@unique([orgId, code])
  @@map("divisions")
}

model Category {
  id         String   @id @default(uuid())
  divisionId String   @map("division_id")
  code       String
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  division      Division      @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]

  @@unique([divisionId, code])
  @@map("categories")
}

model Subcategory {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  code       String
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  costItems CostItem[]

  @@unique([categoryId, code])
  @@map("subcategories")
}

model Region {
  id            String   @id @default(uuid())
  orgId         String?  @map("org_id")
  code          String
  name          String
  laborIndex    Decimal  @default(1.0000) @map("labor_index") @db.Decimal(6, 4)
  materialIndex Decimal  @default(1.0000) @map("material_index") @db.Decimal(6, 4)
  createdAt     DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  laborRates   LaborRate[]
  projects     Project[]

  @@unique([orgId, code])
  @@map("regions")
}

model Supplier {
  id                 String   @id @default(uuid())
  orgId              String?  @map("org_id")
  name               String
  contactEmail       String?  @map("contact_email")
  contactPhone       String?  @map("contact_phone")
  website            String?
  apiIntegrationKey  String?  @map("api_integration_key")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  materials    Material[]
  priceUpdates SupplierPriceUpdate[]

  @@map("suppliers")
}

model Material {
  id               String    @id @default(uuid())
  orgId            String?   @map("org_id")
  sku              String?
  name             String
  unitOfMeasure    String    @map("unit_of_measure")
  unitCost         Decimal   @map("unit_cost") @db.Decimal(12, 4)
  wasteFactorPct   Decimal   @default(0) @map("waste_factor_pct") @db.Decimal(5, 2)
  supplierId       String?   @map("supplier_id")
  lastPriceUpdate  DateTime? @map("last_price_update")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  costItems    CostItem[]
  priceAudits  MaterialPriceAudit[]
  supplierPriceUpdates SupplierPriceUpdate[]

  @@index([orgId])
  @@index([supplierId])
  @@map("materials")
}

model MaterialPriceAudit {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  materialId   String   @map("material_id")
  materialName String   @map("material_name")
  oldUnitCost  Decimal  @map("old_unit_cost") @db.Decimal(12, 4)
  newUnitCost  Decimal  @map("new_unit_cost") @db.Decimal(12, 4)
  source       String   @default("manual")
  actorUserId  String?  @map("actor_user_id")
  actorRole    String?  @map("actor_role")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  material     Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([orgId, createdAt])
  @@index([materialId, createdAt])
  @@map("material_price_audits")
}

// Queued-review staging area for supplier-fed price proposals: a sync job
// (run via runWithBackgroundDatabaseSession) enqueues rows here rather than
// writing straight to Material, so a human reviews/approves before any price
// actually changes. Approval writes the same MaterialPriceAudit trail a
// manual edit would.
model SupplierPriceUpdate {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  supplierId        String   @map("supplier_id")
  materialId        String   @map("material_id")
  currentUnitCost   Decimal  @map("current_unit_cost") @db.Decimal(12, 4)
  proposedUnitCost  Decimal  @map("proposed_unit_cost") @db.Decimal(12, 4)
  status            String   @default("pending")
  source            String   @default("supplier-feed")
  requestedByJob    String?  @map("requested_by_job")
  reviewedByUserId  String?  @map("reviewed_by_user_id")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier     Supplier     @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  material     Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)
  reviewedBy   AppUser?     @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status, createdAt])
  @@index([materialId])
  @@index([supplierId])
  @@map("supplier_price_updates")
}

model LaborRate {
  id              String   @id @default(uuid())
  orgId           String?  @map("org_id")
  trade           String
  baseHourlyRate  Decimal  @map("base_hourly_rate") @db.Decimal(10, 2)
  burdenPct       Decimal  @default(0) @map("burden_pct") @db.Decimal(5, 2)
  regionId        String?  @map("region_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  region       Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  costItems    CostItem[]

  @@index([orgId])
  @@map("labor_rates")
}

model Equipment {
  id                    String   @id @default(uuid())
  orgId                 String?  @map("org_id")
  name                  String
  ownershipCostPerHour  Decimal  @default(0) @map("ownership_cost_per_hour") @db.Decimal(10, 2)
  operatingCostPerHour  Decimal  @default(0) @map("operating_cost_per_hour") @db.Decimal(10, 2)
  dailyRate             Decimal? @map("daily_rate") @db.Decimal(10, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  costItems    CostItem[]

  @@index([orgId])
  @@map("equipment")
}

model Subcontractor {
  id                String   @id @default(uuid())
  orgId             String?  @map("org_id")
  name              String
  trade             String?
  contactEmail      String?  @map("contact_email")
  contactPhone      String?  @map("contact_phone")
  defaultMarkupPct  Decimal  @default(0) @map("default_markup_pct") @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  costItems    CostItem[]

  @@map("subcontractors")
}

model CostItem {
  id               String   @id @default(uuid())
  orgId            String?  @map("org_id")
  subcategoryId    String   @map("subcategory_id")
  code             String
  name             String
  unitOfMeasure    String   @map("unit_of_measure")
  productionRate   Decimal? @map("production_rate") @db.Decimal(12, 4)
  laborRateId      String?  @map("labor_rate_id")
  materialId       String?  @map("material_id")
  equipmentId      String?  @map("equipment_id")
  subcontractorId  String?  @map("subcontractor_id")
  notes            String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  organization     Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subcategory      Subcategory      @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  laborRate        LaborRate?       @relation(fields: [laborRateId], references: [id], onDelete: SetNull)
  material         Material?        @relation(fields: [materialId], references: [id], onDelete: SetNull)
  equipment        Equipment?       @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  subcontractor    Subcontractor?   @relation(fields: [subcontractorId], references: [id], onDelete: SetNull)
  assemblyItems    AssemblyItem[]
  estimateLineItems EstimateLineItem[]
  changeOrderLineItems ChangeOrderLineItem[]

  @@unique([orgId, code])
  @@index([subcategoryId])
  @@map("cost_items")
}

model Assembly {
  id            String   @id @default(uuid())
  orgId         String?  @map("org_id")
  code          String
  name          String
  unitOfMeasure String   @map("unit_of_measure")
  description   String?
  // Marks a reusable starting-point assembly (e.g. "Standard Bathroom
  // Remodel") that an org's estimators browse for quick adds, as distinct
  // from one-off assemblies built for a specific job. Org-scoped, not a
  // cross-tenant catalog — forced RLS would hide a NULL-org_id row from
  // every tenant anyway (NULL = current_app_org_id() is never true), so a
  // shared system-wide template library isn't possible under the current
  // RLS model without a separate mechanism.
  isTemplate    Boolean  @default(false) @map("is_template")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  organization      Organization?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  items             AssemblyItem[]      @relation("AssemblyToItems")
  usedAsChildIn     AssemblyItem[]      @relation("ChildAssembly")
  estimateLineItems EstimateLineItem[]

  @@unique([orgId, code])
  @@index([orgId, isTemplate], map: "idx_assemblies_org_template")
  @@map("assemblies")
}

model AssemblyItem {
  id               String  @id @default(uuid())
  assemblyId       String  @map("assembly_id")
  costItemId       String? @map("cost_item_id")
  childAssemblyId  String? @map("child_assembly_id")
  quantityPerUnit  Decimal @map("quantity_per_unit") @db.Decimal(12, 4)
  sortOrder        Int     @default(0) @map("sort_order")

  assembly      Assembly  @relation("AssemblyToItems", fields: [assemblyId], references: [id], onDelete: Cascade)
  costItem      CostItem? @relation(fields: [costItemId], references: [id], onDelete: Cascade)
  childAssembly Assembly? @relation("ChildAssembly", fields: [childAssemblyId], references: [id], onDelete: Cascade)

  @@index([assemblyId])
  @@map("assembly_items")
}

model Customer {
  id              String   @id @default(uuid())
  orgId           String?  @map("org_id")
  name            String
  email           String?
  phone           String?
  address         String?
  billingAddress  String?  @map("billing_address")
  notes           String?
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projects     Project[]
  serviceAddresses ServiceAddress[]
  equipmentAssets CustomerEquipment[]
  serviceAgreements ServiceAgreement[]
  jobs          Job[]

  @@map("customers")
}

model ServiceAddress {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  customerId   String    @map("customer_id")
  label        String?
  addressLine1 String    @map("address_line_1")
  addressLine2 String?   @map("address_line_2")
  city         String
  state        String
  postalCode   String    @map("postal_code")
  country      String?   @default("US")
  isPrimary    Boolean   @default(false) @map("is_primary")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipmentAssets CustomerEquipment[]
  serviceAgreements ServiceAgreement[]
  jobs         Job[]

  @@index([orgId, customerId])
  @@map("service_addresses")
}

model CustomerEquipment {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  customerId       String    @map("customer_id")
  serviceAddressId String?   @map("service_address_id")
  name             String
  manufacturer     String?
  model            String?
  serialNumber     String?   @map("serial_number")
  installedAt      DateTime? @map("installed_at")
  status           String    @default("active")
  notes            String?
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceAddress ServiceAddress? @relation(fields: [serviceAddressId], references: [id], onDelete: SetNull)
  jobs           JobEquipment[]

  @@index([orgId, customerId])
  @@index([serviceAddressId])
  @@map("customer_equipment")
}

model Project {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")
  customerId  String?  @map("customer_id")
  name        String
  jobType     String?  @map("job_type")
  siteAddress String?  @map("site_address")
  simpleScope String?  @map("simple_scope")
  regionId    String?  @map("region_id")
  status      String   @default("lead")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  region       Region?        @relation(fields: [regionId], references: [id], onDelete: SetNull)
  estimates    Estimate[]
  changeOrders ChangeOrder[]
  proposals    Proposal[]
  invoices     Invoice[]
  contracts    Contract[]
  siteVisits   SiteVisit[]
  projectFiles ProjectFile[]
  tasks        ProjectTask[]
  jobs         Job[]
  serviceAgreements ServiceAgreement[]

  @@index([orgId])
  @@index([customerId])
  @@map("projects")
}

model Estimate {
  id               String   @id @default(uuid())
  orgId            String?  @map("org_id")
  projectId        String   @map("project_id")
  version          Int      @default(1)
  status           String   @default("draft")
  overheadPct      Decimal  @default(0) @map("overhead_pct") @db.Decimal(5, 2)
  profitPct        Decimal  @default(0) @map("profit_pct") @db.Decimal(5, 2)
  targetMarginPct  Decimal? @map("target_margin_pct") @db.Decimal(5, 2)
  subtotalCost     Decimal  @default(0) @map("subtotal_cost") @db.Decimal(14, 2)
  totalPrice       Decimal  @default(0) @map("total_price") @db.Decimal(14, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

