  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments  TagAssignment[]

  @@unique([orgId, slug])
  @@index([orgId, name])
  @@map("tags")
}

model TagAssignment {
  id               String   @id @default(uuid())
  orgId            String   @map("org_id")
  tagId            String   @map("tag_id")
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  assignedByUserId String?  @map("assigned_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedByUser AppUser?   @relation(fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([orgId, tagId, entityType, entityId])
  @@index([orgId, entityType, entityId])
  @@map("tag_assignments")
}

model SavedView {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  entityType      String   @map("entity_type")
  name            String
  description     String?
  filterJson      Json     @map("filter_json")
  sortJson        Json?    @map("sort_json")
  isShared        Boolean  @default(false) @map("is_shared")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUser AppUser? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, entityType, updatedAt])
  @@map("saved_views")
}

model RecentItem {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  userId      String   @map("user_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  title       String
  subtitle    String?
  href        String
  keywordsJson Json?   @map("keywords_json")
  metadataJson Json?   @map("metadata_json")
  updatedAtIso String? @map("updated_at_iso")
  lastViewedAt DateTime @default(now()) @map("last_viewed_at")
  viewCount   Int      @default(1) @map("view_count")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, entityType, entityId])
  @@index([orgId, userId, lastViewedAt])
  @@map("recent_items")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  key         String
  description String?
  enabled     Boolean  @default(false)
  scopeType   String   @default("org") @map("scope_type")
  scopeKey    String?  @map("scope_key")
  metadataJson Json?   @map("metadata_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key, scopeType, scopeKey])
  @@index([orgId, key])
  @@map("feature_flags")
}
