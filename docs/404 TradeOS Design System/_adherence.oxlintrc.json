{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/chrome/**",
              "components/core/**",
              "ui_kits/costbook/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge404'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<Badge404> doesn't accept that prop. Declared props: className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlinkingCursor'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<BlinkingCursor> doesn't accept that prop. Declared props: className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|as|href|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, as, href, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|panel)$/]",
        "message": "<Card> variant must be one of 'card' | 'panel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerBrackets'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|className|style|key|ref|className|style|children)$/]",
        "message": "<CornerBrackets> doesn't accept that prop. Declared props: size, color, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OSModuleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|id|title|body|from|time|version|as|href|className|style|key|ref|className|style|children)$/]",
        "message": "<OSModuleCard> doesn't accept that prop. Declared props: icon, id, title, body, from, time, version, as, href, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OSModuleCard'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:a|div)$/]",
        "message": "<OSModuleCard> as must be one of 'a' | 'div'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SecLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|style|key|ref|className|style|children)$/]",
        "message": "<SecLabel> doesn't accept that prop. Declared props: children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLED'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|className|style|key|ref|className|style|children)$/]",
        "message": "<StatusLED> doesn't accept that prop. Declared props: status, label, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLED'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|processing|error|idle)$/]",
        "message": "<StatusLED> status must be one of 'online' | 'processing' | 'error' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|className|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, dot, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:online|neutral|copper)$/]",
        "message": "<StatusPill> tone must be one of 'online' | 'neutral' | 'copper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|status|statusLabel|actions|children|className|style|key|ref|className|style|children)$/]",
        "message": "<TerminalFrame> doesn't accept that prop. Declared props: title, status, statusLabel, actions, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalFrame'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|processing|error|idle)$/]",
        "message": "<TerminalFrame> status must be one of 'online' | 'processing' | 'error' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|className|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: size, tone, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Wordmark> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Wordmark> tone must be one of 'dark' | 'light'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
