{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssemblySchema",
  "description": "Schema for grouped contractor assemblies linking items with quantities and metadata",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the assembly"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-safe unique identifier slug"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic versioning tag"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "trade": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "customerDescription": {
      "type": "string"
    },
    "contractorNotes": {
      "type": "string"
    },
    "typicalUseCase": {
      "type": "string"
    },
    "projectTypes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constructionPhase": {
      "type": "string"
    },
    "requiredInputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "optionalInputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lineItems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "costBookItemId": {
            "type": "string",
            "format": "uuid"
          },
          "quantity": {
            "type": "number",
            "minimum": 0.0
          }
        },
        "required": ["costBookItemId", "quantity"],
        "additionalProperties": false
      }
    },
    "materialCategories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "laborCategories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "equipmentCategories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "safetyRequirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "riskFactors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permitAwareness": {
      "type": "string"
    },
    "inspectionAwareness": {
      "type": "string"
    },
    "codeConsiderations": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wasteDisposal": {
      "type": "string"
    },
    "proposalScopeOfWork": {
      "type": "string"
    },
    "proposalAssumptions": {
      "type": "string"
    },
    "proposalExclusions": {
      "type": "string"
    },
    "warrantyLanguage": {
      "type": "string"
    },
    "productionNotes": {
      "type": "string"
    },
    "futurePricingHooks": {
      "type": "string"
    },
    "futureAINotes": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "slug",
    "version",
    "created",
    "updated",
    "trade",
    "category",
    "name",
    "description"
  ],
  "additionalProperties": false,
  "x-future-extensions": {
    "dynamic_estimation_logic": "Formula-based parsing for quantity calculations based on dimension inputs"
  }
}
